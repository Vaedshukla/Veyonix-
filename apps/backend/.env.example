# ================================================================
# Veyonix Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ================================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Veyonix
APP_VERSION=0.1.0
APP_PORT=3000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL="postgresql://veyonix:veyonix_dev_password@localhost:5433/veyonix?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=veyonix:

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_THIS_ACCESS_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MIN_64_CHARS
JWT_AGENT_SECRET=CHANGE_THIS_AGENT_SECRET_MIN_64_CHARS
JWT_ACCESS_TTL=900          # 15 minutes in seconds
JWT_REFRESH_TTL=2592000     # 30 days in seconds
JWT_AGENT_TTL=3600          # 1 hour in seconds

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000

# ── Storage ──────────────────────────────────────────────────
STORAGE_PROVIDER=LOCAL        # LOCAL | S3 | CLOUDFLARE_R2 | AZURE_BLOB
STORAGE_LOCAL_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # for Cloudflare R2

# ── Mail ─────────────────────────────────────────────────────
MAIL_PROVIDER=SMTP            # RESEND | SES | SMTP | SENDGRID
MAIL_FROM_NAME=Veyonix
MAIL_FROM_ADDRESS=noreply@veyonix.com
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# For local dev, use Mailpit on localhost:1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# ── Agent ────────────────────────────────────────────────────
AGENT_HEARTBEAT_INTERVAL_MS=30000
AGENT_OFFLINE_THRESHOLD_MS=120000
AGENT_MAX_CONNECTIONS=10000
AGENT_JWT_CERTIFICATE_TTL_DAYS=365

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug               # trace | debug | info | warn | error | fatal
LOG_PRETTY=true               # true for dev, false for prod

# ── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_HOST=localhost:3000

# ── Feature Flags Cache ──────────────────────────────────────
FEATURE_FLAG_CACHE_TTL_MS=60000
