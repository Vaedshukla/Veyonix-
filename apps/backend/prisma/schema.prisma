generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, uuidOssp(map: "uuid-ossp")]
}

// ================================================================
// ENUMS
// ================================================================

enum OrganizationType {
  SCHOOL_DISTRICT
  SCHOOL
  FAMILY
  ENTERPRISE
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditSource {
  WEB
  AGENT
  SYSTEM
  API
}

enum IdentityAuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  EMAIL_VERIFIED
  ROLE_ASSIGNED
  ROLE_REVOKED
  SESSION_REVOKED
}

// ================================================================
// MULTI-TENANCY
// ================================================================

model Tenant {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String         @unique // Lowercase, DNS-safe format
  isActive      Boolean        @default(true)
  organizations Organization[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@map("tenants")
}

model Organization {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String                   @db.Uuid
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name        String
  slug        String                   @unique
  type        OrganizationType
  isActive    Boolean                  @default(true)
  memberships OrganizationMembership[]
  roles       Role[]
  auditLogs   AuditLog[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@map("organizations")
}

// ================================================================
// USERS & MEMBERSHIPS
// ================================================================

model User {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String
  normalizedEmail    String                   @unique // Always lowercased and trimmed for auth
  passwordHash       String
  firstName          String
  lastName           String
  isActive           Boolean                  @default(true)
  isEmailVerified    Boolean                  @default(false)
  lastLoginAt        DateTime?
  version            Int                      @default(1)
  memberships        OrganizationMembership[]
  refreshTokens      RefreshToken[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  auditLogs          AuditLog[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?

  @@index([normalizedEmail])
  @@map("users")
}

model OrganizationMembership {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean      @default(true)
  roles          UserRole[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

// ================================================================
// RBAC (ROLES & PERMISSIONS)
// ================================================================

model Role {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?          @db.Uuid // Null for System/Tenant-wide roles
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  isSystem       Boolean          @default(false)
  isDefault      Boolean          @default(false)
  priority       Int              @default(0) // Higher resolves conflicts
  version        Int              @default(1)
  permissions    RolePermission[]
  memberships    UserRole[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String           @unique // e.g. "users.read", "devices.manage"
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("permissions")
}

model RolePermission {
  roleId       String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  membershipId String                 @db.Uuid
  membership   OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  roleId       String                 @db.Uuid
  role         Role                   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime               @default(now())

  @@id([membershipId, roleId])
  @@map("user_roles")
}

// ================================================================
// SESSIONS & REFRESH TOKENS
// ================================================================

model Session {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName    String?
  deviceType    String?
  platform      String?
  browser       String?
  location      String?
  ipAddress     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

model RefreshToken {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash          String    @unique
  familyId           String    @db.Uuid
  rotatedFromTokenId String?   @db.Uuid
  rotationCounter    Int       @default(0)
  expiresAt          DateTime
  usedAt             DateTime?
  revokedAt          DateTime?
  userAgent          String?
  ipAddress          String?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ================================================================
// RECOVERY & VERIFICATION
// ================================================================

model EmailVerification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("email_verifications")
}

model PasswordReset {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash       String    @unique
  requestedAt     DateTime  @default(now())
  requestedFromIp String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@map("password_resets")
}

// ================================================================
// AUDIT LOG
// ================================================================

model AuditLog {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  correlationId  String?
  requestId      String?
  source         AuditSource         @default(SYSTEM)
  severity       AuditSeverity       @default(INFO)
  organizationId String?             @db.Uuid
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorId        String?             @db.Uuid
  actor          User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action         IdentityAuditAction
  targetId       String?             @db.Uuid
  details        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime            @default(now())

  @@index([organizationId])
  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([correlationId])
  @@map("audit_logs")
}
